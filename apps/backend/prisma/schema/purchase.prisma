model PurchaseMasterData {
  id             String        @id @default(uuid())
  modelId        Int           @unique @map("model_id")
  supplier       String        @db.VarChar(255)
  unitPrice      Decimal       @map("unit_price") @db.Decimal(15, 2)
  quantity       Int
  totalPrice     Decimal       @map("total_price") @db.Decimal(15, 2)
  purchaseDate   DateTime      @map("purchase_date") @db.Date
  warrantyMonths Int?          @map("warranty_months")
  invoiceNumber  String?       @map("invoice_number") @db.VarChar(100)
  note           String?
  createdById    Int           @map("created_by_id")
  isDeleted      Boolean       @default(false) @map("is_deleted")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  depreciation   Depreciation?
  createdBy      User          @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  model          AssetModel    @relation(fields: [modelId], references: [id])

  @@index([supplier])
  @@index([purchaseDate])
  @@map("purchase_master_data")
}

model Depreciation {
  id              String             @id @default(uuid())
  purchaseId      String             @unique @map("purchase_id")
  method          DepreciationMethod
  usefulLifeYears Int                @map("useful_life_years")
  salvageValue    Decimal            @map("salvage_value") @db.Decimal(15, 2)
  startDate       DateTime           @map("start_date") @db.Date
  createdById     Int                @map("created_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  createdBy       User               @relation("DepreciationCreatedBy", fields: [createdById], references: [id])
  purchase        PurchaseMasterData @relation(fields: [purchaseId], references: [id])

  @@index([method])
  @@map("depreciations")
}
