model User {
  id                   Int                  @id @default(autoincrement())
  uuid                 String               @unique @default(uuid())
  employeeId           String               @unique @map("employee_id") @db.VarChar(20)
  fullName             String               @map("full_name") @db.VarChar(255)
  email                String               @unique @db.VarChar(255)
  password             String               @db.VarChar(255)
  role                 UserRole             @default(STAFF)
  divisionId           Int?                 @map("division_id")
  permissions          Json?
  phone                String?              @db.VarChar(20)
  avatarUrl            String?              @map("avatar_url") @db.VarChar(500)
  isActive             Boolean              @default(true) @map("is_active")
  isDeleted            Boolean              @default(false) @map("is_deleted")
  tokenVersion         Int                  @default(0) @map("token_version")
  lastLoginAt          DateTime?            @map("last_login_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  mustChangePassword   Boolean              @default(false) @map("must_change_password")
  activityLogs         ActivityLog[]
  createdAssetReturns  AssetReturn[]        @relation("AssetReturnCreatedBy")
  currentAssets        Asset[]              @relation("AssetCurrentUser")
  recordedAssets       Asset[]              @relation("AssetRecordedBy")
  attachments          Attachment[]         @relation("AttachmentUploadedBy")
  createdDepreciations Depreciation[]       @relation("DepreciationCreatedBy")
  handoversFrom        Handover[]           @relation("HandoverFrom")
  handoversTo          Handover[]           @relation("HandoverTo")
  handoversWitness     Handover[]           @relation("HandoverWitness")
  createdLoanRequests  LoanRequest[]        @relation("LoanRequestCreatedBy")
  notifications        Notification[]
  createdPurchases     PurchaseMasterData[] @relation("PurchaseCreatedBy")
  createdRepairs       Repair[]             @relation("RepairCreatedBy")
  createdRequests      Request[]            @relation("RequestCreatedBy")
  stockMovements       StockMovement[]      @relation("StockMovementCreatedBy")
  stockThresholds      StockThreshold[]     @relation("StockThresholdCreatedBy")
  division             Division?            @relation(fields: [divisionId], references: [id])

  @@index([role])
  @@index([divisionId])
  @@index([isActive, isDeleted])
  @@map("users")
}

model Division {
  id             Int      @id @default(autoincrement())
  uuid           String   @unique @default(uuid())
  name           String   @unique @db.VarChar(255)
  code           String   @unique @db.VarChar(10)
  description    String?
  canDoFieldwork Boolean  @default(false) @map("can_do_fieldwork")
  isActive       Boolean  @default(true) @map("is_active")
  isDeleted      Boolean  @default(false) @map("is_deleted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  users          User[]

  @@map("divisions")
}

enum UserRole {
  SUPERADMIN
  ADMIN_LOGISTIK
  ADMIN_PURCHASE
  LEADER
  STAFF
}
