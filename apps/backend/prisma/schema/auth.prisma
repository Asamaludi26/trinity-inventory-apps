// =============================================
// AUTH SCHEMA — User, Division, UserRole
// Domain: Authentication & Settings (F-06)
// Ref: SDD 4.1, PRD 7.1
// =============================================

enum UserRole {
  SUPERADMIN
  ADMIN_LOGISTIK
  ADMIN_PURCHASE
  LEADER
  STAFF
}

model User {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid())
  employeeId    String   @unique @map("employee_id") @db.VarChar(20)
  fullName      String   @map("full_name") @db.VarChar(255)
  email         String   @unique @db.VarChar(255)
  password      String   @db.VarChar(255)
  role          UserRole @default(STAFF)
  divisionId    Int?     @map("division_id")
  permissions   Json?    @db.JsonB
  phone         String?  @db.VarChar(20)
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  tokenVersion  Int      @default(0) @map("token_version")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  division Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  // Reverse relations
  recordedAssets        Asset[]              @relation("AssetRecordedBy")
  currentAssets         Asset[]              @relation("AssetCurrentUser")
  stockThresholds       StockThreshold[]     @relation("StockThresholdCreatedBy")
  stockMovements        StockMovement[]      @relation("StockMovementCreatedBy")
  attachments           Attachment[]         @relation("AttachmentUploadedBy")
  activityLogs          ActivityLog[]
  notifications         Notification[]
  createdRequests       Request[]            @relation("RequestCreatedBy")
  createdLoanRequests   LoanRequest[]        @relation("LoanRequestCreatedBy")
  createdAssetReturns   AssetReturn[]        @relation("AssetReturnCreatedBy")
  handoversFrom         Handover[]           @relation("HandoverFrom")
  handoversTo           Handover[]           @relation("HandoverTo")
  handoversWitness      Handover[]           @relation("HandoverWitness")
  createdDepreciations  Depreciation[]       @relation("DepreciationCreatedBy")
  createdPurchases      PurchaseMasterData[] @relation("PurchaseCreatedBy")
  createdRepairs        Repair[]             @relation("RepairCreatedBy")

  @@index([role])
  @@index([divisionId])
  @@index([isActive, isDeleted])
  @@map("users")
}

model Division {
  id              Int      @id @default(autoincrement())
  uuid            String   @unique @default(uuid())
  name            String   @unique @db.VarChar(255)
  code            String   @unique @db.VarChar(10)
  description     String?  @db.Text
  canDoFieldwork  Boolean  @default(false) @map("can_do_fieldwork")
  isActive        Boolean  @default(true) @map("is_active")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  users User[]

  @@map("divisions")
}
